<Window x:Class="AdminWPF.Windows.BejelentkezesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Délibáb Étterem – Bejelentkezés"
        Height="380" Width="380"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#1E1E2E">

    <Window.Resources>
        <Style x:Key="InputBox" TargetType="TextBox">
            <Setter Property="FontFamily"       Value="Segoe UI"/>
            <Setter Property="FontSize"         Value="13"/>
            <Setter Property="Padding"          Value="10,8"/>
            <Setter Property="Background"       Value="#2D2D3F"/>
            <Setter Property="Foreground"       Value="White"/>
            <Setter Property="BorderBrush"      Value="#44445A"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="CaretBrush"       Value="White"/>
        </Style>
        <Style x:Key="PassBox" TargetType="PasswordBox">
            <Setter Property="FontFamily"       Value="Segoe UI"/>
            <Setter Property="FontSize"         Value="13"/>
            <Setter Property="Padding"          Value="10,8"/>
            <Setter Property="Background"       Value="#2D2D3F"/>
            <Setter Property="Foreground"       Value="White"/>
            <Setter Property="BorderBrush"      Value="#44445A"/>
            <Setter Property="BorderThickness"  Value="1"/>
        </Style>
    </Window.Resources>

    <StackPanel VerticalAlignment="Center" Margin="40,30">

        <!-- Ikon + Cím -->
        <TextBlock Text="🍽️" FontSize="36" HorizontalAlignment="Center" Margin="0,0,0,4"/>
        <TextBlock Text="Délibáb Étterem"
                   FontFamily="Segoe UI" FontSize="18" FontWeight="Bold"
                   Foreground="White" HorizontalAlignment="Center"/>
        <TextBlock Text="Admin bejelentkezés"
                   FontFamily="Segoe UI" FontSize="11"
                   Foreground="#8888AA" HorizontalAlignment="Center"
                   Margin="0,2,0,24"/>

        <!-- Email -->
        <TextBlock Text="Email cím" FontFamily="Segoe UI" FontSize="11"
                   Foreground="#AAAACC" Margin="0,0,0,4"/>
        <TextBox x:Name="txtEmail" Style="{StaticResource InputBox}"
                 KeyDown="Input_KeyDown"/>

        <!-- Jelszó -->
        <TextBlock Text="Jelszó" FontFamily="Segoe UI" FontSize="11"
                   Foreground="#AAAACC" Margin="0,14,0,4"/>
        <PasswordBox x:Name="pbJelszo" Style="{StaticResource PassBox}"
                     KeyDown="Input_KeyDown"/>

        <!-- Hibaüzenet -->
        <TextBlock x:Name="txtHiba" FontFamily="Segoe UI" FontSize="11"
                   Foreground="#FF6B6B" Margin="0,10,0,0"
                   TextWrapping="Wrap" Visibility="Collapsed"/>

        <!-- Bejelentkezés gomb -->
        <Button x:Name="btnBelepes" Content="Bejelentkezés"
                Margin="0,20,0,0" Height="40"
                Background="#5865F2" Foreground="White"
                FontFamily="Segoe UI" FontWeight="Bold" FontSize="13"
                BorderThickness="0" Cursor="Hand"
                Click="BtnBelepes_Click">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="6" Padding="0">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#4752C4"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Background" Value="#444466"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>
        </Button>

        <TextBlock Text="Csak admin jogosultságú fiókkal lehet belépni."
                   FontFamily="Segoe UI" FontSize="10"
                   Foreground="#555570" HorizontalAlignment="Center"
                   Margin="0,14,0,0" TextWrapping="Wrap"
                   TextAlignment="Center"/>
    </StackPanel>
</Window>
