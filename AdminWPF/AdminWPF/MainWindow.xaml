<Window x:Class="AdminWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AdminWPF"
        mc:Ignorable="d"
        Title="Délibáb Étterem - Admin Felület"
        Height="700" Width="1300"
        MinHeight="620" MinWidth="820"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">

    <Window.Resources>
        <Style x:Key="GreenButton" TargetType="Button">
            <Setter Property="Background" Value="#28A745"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#218838"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="RedButton" TargetType="Button" BasedOn="{StaticResource GreenButton}">
            <Setter Property="Background" Value="#DC3545"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#C82333"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="BlueButton" TargetType="Button" BasedOn="{StaticResource GreenButton}">
            <Setter Property="Background" Value="#007BFF"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="46"/>
            <Setter Property="Padding" Value="18,0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#0056B3"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="GrayButton" TargetType="Button" BasedOn="{StaticResource GreenButton}">
            <Setter Property="Background" Value="#6C757D"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Height" Value="46"/>
            <Setter Property="Padding" Value="18,0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#5A6268"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="RedButtonInaktiv" TargetType="Button" BasedOn="{StaticResource GreenButton}">
            <Setter Property="Background" Value="#e8a0a7"/>
            <Setter Property="Foreground" Value="#c0c0c0"/>
            <Setter Property="Cursor" Value="Arrow"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#e8a0a7"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="GroupBoxStyle" TargetType="GroupBox">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="9"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="5"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ═══ FEJLÉC ═══ -->
        <Border Grid.Row="0" Background="#2D2D30" Padding="20,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Cím -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Source="/delibab_ikon.png" Width="32" Height="32" Margin="0,0,10,0"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                    <Label Content="Délibáb Étterem - Admin"
                           FontFamily="Segoe UI" FontSize="18" FontWeight="Bold"
                           Foreground="White" VerticalAlignment="Center" Padding="0"/>
                </StackPanel>

                <!-- ── VÁLTOZÁS TRACKER BADGE ── -->
                <Border x:Name="badgeValtozas"
                        Grid.Column="2"
                        Background="#E67E22"
                        CornerRadius="12"
                        Padding="10,4"
                        VerticalAlignment="Center"
                        Margin="0,0,14,0"
                        Visibility="Collapsed">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="✏ "
                                   Foreground="White" FontSize="11"
                                   VerticalAlignment="Center"/>
                        <TextBlock x:Name="txtBadgeSzam"
                                   Foreground="White" FontSize="11" FontWeight="Bold"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text=" mentetlen változás"
                                   Foreground="White" FontSize="11"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Status label -->
                <Label x:Name="labelStatus"
                       Grid.Column="3"
                       Content="Betöltés..."
                       FontFamily="Segoe UI" FontSize="10"
                       Foreground="#D3D3D3"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Right"
                       Margin="0,0,0,0"/>
            </Grid>
        </Border>

        <!-- ═══ GOMBOK ═══ -->
        <Border Grid.Row="1" Background="#F0F0F0" Padding="10">
            <WrapPanel Orientation="Horizontal" HorizontalAlignment="Left">

                <GroupBox Header="🪑 Asztal kezelés"
                          Style="{StaticResource GroupBoxStyle}"
                          Width="270" Height="90">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="btnAsztalHozzaad"
                                Content="+ Asztal"
                                Style="{StaticResource GreenButton}"
                                Width="110" Height="40"
                                Click="BtnAsztalHozzaad_Click"/>
                        <Button x:Name="btnAsztalTorol"
                                Content="- Törlés"
                                Style="{StaticResource RedButtonInaktiv}"
                                Width="110" Height="40"
                                Margin="15,0,0,0"
                                IsEnabled="False"
                                Click="BtnAsztalTorol_Click"/>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="🕐 Időpont kezelés"
                          Style="{StaticResource GroupBoxStyle}"
                          Width="295" Height="90">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="btnIdopontHozzaad"
                                Content="+ Időpont"
                                Style="{StaticResource GreenButton}"
                                Width="120" Height="40"
                                Click="BtnIdopontHozzaad_Click"/>
                        <Button x:Name="btnIdopontTorol"
                                Content="- Törlés"
                                Style="{StaticResource RedButtonInaktiv}"
                                Width="110" Height="40"
                                Margin="15,0,0,0"
                                IsEnabled="False"
                                Click="BtnIdopontTorol_Click"/>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="📅 Foglalás dátuma"
                          Style="{StaticResource GroupBoxStyle}"
                          Width="230" Height="90">
                    <StackPanel VerticalAlignment="Center">
                        <ComboBox x:Name="cmbDatum"
                                  Width="200" Height="34"
                                  FontFamily="Segoe UI" FontSize="11"
                                  SelectionChanged="CmbDatum_SelectionChanged"/>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="👤 Felhasználó kezelése"
                          Style="{StaticResource GroupBoxStyle}"
                          Width="210" Height="90">
                    <StackPanel VerticalAlignment="Center">
                        <Button x:Name="btnFelhasznaloKezeles"
                                Content="⚙ Kezelés"
                                Style="{StaticResource GreenButton}"
                                Width="170" Height="40"
                                Click="BtnFelhasznaloKezeles_Click"/>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="💾 Műveletek"
                          Style="{StaticResource GroupBoxStyle}"
                          Width="460" Height="90">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="btnMentes"
                                Content="💾 MENTÉS"
                                Style="{StaticResource BlueButton}"
                                Width="210" Height="46"
                                Click="BtnMentes_Click"/>
                        <Button x:Name="btnFrissites"
                                Content="🔄 Frissítés API-ból"
                                Style="{StaticResource GrayButton}"
                                Width="205" Height="46"
                                Margin="15,0,0,0"
                                Click="BtnFrissites_Click"/>
                    </StackPanel>
                </GroupBox>

            </WrapPanel>
        </Border>

        <!-- ═══ RÁCS ═══ -->
        <Border Grid.Row="2" Background="White" Padding="20">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                <Grid x:Name="gridFoglalas"/>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
